[
  {
    "type": 1,
    "title": "Nextcloud (Optimiert)",
    "name": "nextcloud",
    "description": "Nextcloud mit sauber getrennten Pfaden für Konfiguration, Apps und deine privaten Daten.",
    "logo": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/nextcloud.png",
    "image": "nextcloud:latest",
    "categories": [
      "Cloud",
      "Tools"
    ],
    "platform": "linux",
    "restart_policy": "unless-stopped",
    "ports": [
      {
        "WebUI": "8080:80/tcp"
      }
    ],
    "volumes": [
      {
        "container": "/var/www/html/config",
        "bind": "!config/Nextcloud/config"
      },
      {
        "container": "/var/www/html/data",
        "bind": "!config/Nextcloud/data"
      },
      {
        "container": "/var/www/html/custom_apps",
        "bind": "!config/Nextcloud/apps"
      }
    ],
    "env": [
      {
        "name": "TZ",
        "label": "TZ",
        "default": "Europe/Berlin"
      }
    ]
  },
  {
    "type": 1,
    "title": "MariaDB",
    "name": "mariadb",
    "description": "Eine schnelle, robuste und relationale SQL-Datenbank. Ideal als leistungsstarkes Backend für Nextcloud.",
    "logo": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/mariadb.png",
    "image": "mariadb:latest",
    "categories": [
      "Database"
    ],
    "platform": "linux",
    "restart_policy": "unless-stopped",
    "ports": [
      {
        "3306": "3306/tcp"
      }
    ],
    "volumes": [
      {
        "container": "/var/lib/mysql",
        "bind": "!config/mariadb"
      }
    ],
    "env": [
      {
        "name": "MYSQL_ROOT_PASSWORD",
        "label": "Root Passwort",
        "default": "root_passwort_hier_aendern"
      },
      {
        "name": "MYSQL_DATABASE",
        "label": "Datenbank Name",
        "default": "nextcloud"
      },
      {
        "name": "MYSQL_USER",
        "label": "Datenbank Benutzer",
        "default": "nextcloud_user"
      },
      {
        "name": "MYSQL_PASSWORD",
        "label": "Benutzer Passwort",
        "default": "user_passwort_hier_aendern"
      }
    ]
  }
]