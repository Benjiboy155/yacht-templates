[
  {
      "type": 1,
      "title": "Nextcloud",
      "name": "nextcloud",
      "description": "Nextcloud ist eine sichere und quelloffene Cloud-Plattform. Speichere deine Dokumente, Kalender, Kontakte und Fotos auf deinem eigenen Server und teile sie sicher mit anderen.",
      "logo": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/nextcloud.png",
      "image": "nextcloud:latest",
      "categories": [
        "Cloud",
        "Tools"
      ],
      "platform": "linux",
      "restart_policy": "unless-stopped",
      "ports": [
        {
          "WebUI": "8080:80/tcp"
        }
      ],
      "volumes": [
        {
          "container": "/var/www/html",
          "bind": "!config/Nextcloud"
        }
      ],
      "env": [
        {
          "name": "TZ",
          "label": "TZ",
          "default": "Europe/Berlin"
        }
      ]
    }
  ]